    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-fastify": "^11.1.3",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/terminus": "^11.0.0",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.43.1",
    "fastify": "^5.4.0",
    "ioredis": "^5.6.1",
    "pg": "^8.14.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^3.25.51"
  },
  "devDependencies": {
