FROM node:22-alpine

RUN npm install -g pnpm@9

WORKDIR /app

# Copy workspace manifests for dependency caching
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml ./
COPY apps/web/package.json ./apps/web/package.json

# Install only web app dependencies
RUN pnpm install --filter @saas-ops/web...

COPY apps/web ./apps/web

WORKDIR /app/apps/web

EXPOSE 3000

# Re-run install on startup so the named volume for node_modules gets
# populated even when the bind mount hides the image's apps/web directory.
# Uses --prefer-offline since the pnpm store is already in the image.
CMD ["sh", "-c", "cd /app && pnpm install --filter @saas-ops/web... --prefer-offline && pnpm --filter @saas-ops/web dev"]
